<Window x:Class="Paperhome.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Paperhome.Views"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Paperwork" Height="700" Width="1150"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#181818"
        TextElement.FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
        TextOptions.TextFormattingMode="Display">
    
    <Window.Resources>
        <DataTemplate x:Key="ArchiveViewTemplate">
            <!-- Included in standard XAML -->
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="8" Background="#181818" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" /> <RowDefinition Height="50" /> <RowDefinition Height="*" />  </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#181818" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="Paperhome" 
                           Foreground="#888888" 
                           VerticalAlignment="Center" 
                           Margin="15,0,0,0" 
                           FontWeight="Bold" />
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="40" Background="Transparent" BorderThickness="0" Foreground="#888888" Click="Minimize_Click">
                        <iconPacks:PackIconPixelartIcons Kind="Minus" Width="12" Height="12"/>
                    </Button>
                    <Button Width="40" Background="Transparent" BorderThickness="0" Foreground="#888888" Click="Close_Click">
                        <iconPacks:PackIconPixelartIcons Kind="Close" Width="12" Height="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Grid.Row="1" Background="#222222" Margin="0,0,0,0">
                <StackPanel.Effect>
                    <DropShadowEffect BlurRadius="0" ShadowDepth="4" Direction="270" Opacity="0.5" Color="Black"/>
                </StackPanel.Effect>
                
                <Button x:Name="BtnAdd" Style="{StaticResource MechanicalButton}" Margin="15,6,5,6" Click="BtnAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconPixelartIcons Kind="Plus" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ДОБАВИТЬ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnDelete" Style="{StaticResource MechanicalButton}" Margin="5,6,5,6" Click="BtnDelete_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconPixelartIcons Kind="Delete" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="УДАЛИТЬ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MechanicalButton}" Margin="5,6,5,6">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconPixelartIcons Kind="Sliders" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ПАРАМЕТРЫ" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Grid Grid.Row="2" Background="{StaticResource SteppedDeskGradient}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="15" /> 
                    <ColumnDefinition Width="*" />   
                    <ColumnDefinition Width="15" /> 
                    <ColumnDefinition Width="380" /> 
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="15,15,0,15">
                    <views:ArchiveView />
                </Grid>

                <Grid Grid.Column="2" Margin="0,15,0,15">
                    <views:InspectorView />
                </Grid>

                <ContentControl Grid.Column="4" Style="{StaticResource PixelBox}" Background="#222222" BorderBrush="#111" Margin="0,15,15,15">
                    <ContentControl.Effect>
                        <DropShadowEffect BlurRadius="0" ShadowDepth="6" Direction="315" Opacity="0.5" Color="Black"/>
                    </ContentControl.Effect>
                    <TextBlock Text="[ЗОНА МЕТАДАННЫХ И ИИ]" Foreground="#666"/>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
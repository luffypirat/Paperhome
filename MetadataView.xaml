<UserControl x:Class="Paperhome.Views.MetadataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="380">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок-таб -->
        <Border Grid.Row="0" Background="#1F1F1F" BorderBrush="#111" BorderThickness="2,2,2,0"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <TextBlock Text="ИНФОРМАЦИЯ" Foreground="#AAAAAA" FontWeight="Bold" Padding="15,0" VerticalAlignment="Center"/>
        </Border>

        <!-- Фон с тенью -->
        <Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#111" BorderThickness="2"
                RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="0" ShadowDepth="6" Direction="315" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <!-- Тело КПК -->
        <ScrollViewer Grid.Row="1" Margin="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,12,12,16">

                <!-- Имя файла -->
                <TextBlock Text="ФАЙЛ" Foreground="#888" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <Border Background="#0A0A0A" BorderBrush="#2A2A2A" BorderThickness="2" Margin="0,0,0,12">
                    <Border BorderBrush="#333" BorderThickness="0,0,1,1" Padding="8,6">
                        <TextBlock x:Name="TxtDocName" Text="—" Foreground="#8AAA8A"
                                   FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                   FontSize="12"
                                   TextWrapping="Wrap" TextTrimming="None"/>
                    </Border>
                </Border>

                <!-- Название -->
                <TextBlock Text="НАЗВАНИЕ" Foreground="#888" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <Border Background="#0A0A0A" BorderBrush="#2A2A2A" BorderThickness="2" Margin="0,0,0,12">
                    <Border BorderBrush="#333" BorderThickness="0,0,1,1">
                        <TextBox x:Name="TxtTitle"
                                 Background="Transparent" Foreground="#E8B84A"
                                 FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                 FontSize="12"
                                 BorderThickness="0" Padding="8,7" TextWrapping="Wrap"
                                 CaretBrush="#E8B84A" SelectionBrush="#E8B84A"
                                 TextChanged="Fields_TextChanged"/>
                    </Border>
                </Border>

                <!-- Теги -->
                <TextBlock Text="ТЕГИ (через запятую)" Foreground="#888" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <Border Background="#0A0A0A" BorderBrush="#2A2A2A" BorderThickness="2" Margin="0,0,0,12">
                    <Border BorderBrush="#333" BorderThickness="0,0,1,1">
                        <TextBox x:Name="TxtTags"
                                 Background="Transparent" Foreground="#E8B84A"
                                 FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                 FontSize="12"
                                 BorderThickness="0" Padding="8,7" TextWrapping="Wrap"
                                 CaretBrush="#E8B84A" SelectionBrush="#E8B84A"
                                 TextChanged="Fields_TextChanged"/>
                    </Border>
                </Border>

                <!-- Описание -->
                <TextBlock Text="ОПИСАНИЕ" Foreground="#888" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <Border Background="#0A0A0A" BorderBrush="#2A2A2A" BorderThickness="2" Margin="0,0,0,12">
                    <Border BorderBrush="#333" BorderThickness="0,0,1,1">
                        <TextBox x:Name="TxtSummary"
                                 Background="Transparent" Foreground="#E8B84A"
                                 FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                 FontSize="12"
                                 BorderThickness="0" Padding="8,7" TextWrapping="Wrap"
                                 MinHeight="80" AcceptsReturn="True"
                                 CaretBrush="#E8B84A" SelectionBrush="#E8B84A"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 TextChanged="Fields_TextChanged"/>
                    </Border>
                </Border>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button x:Name="BtnAnalyze" Style="{StaticResource MechanicalButton}"
                            Margin="0,0,8,0" Padding="10,6" Click="BtnAnalyze_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconPixelartIcons Kind="Zap" Width="14" Height="14"
                                                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="АНАЛИЗ ИИ" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSave" Style="{StaticResource MechanicalButton}"
                            Padding="10,6" Click="BtnSave_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconPixelartIcons Kind="Save" Width="14" Height="14"
                                                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="СОХРАНИТЬ" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Терминал статуса -->
                <Border Background="#050808" BorderBrush="#1A2A1A" BorderThickness="2"
                        Margin="0,0,0,14" MinHeight="72" Padding="1">
                    <Border BorderBrush="#1E3A1E" BorderThickness="1,1,0,0" Padding="8,7">
                        <TextBlock x:Name="TxtStatus"
                                   Text="> ОЖИДАНИЕ..."
                                   Foreground="#60C040"
                                   FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                   FontSize="14"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </Border>
                </Border>

             

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

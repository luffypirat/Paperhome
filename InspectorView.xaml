<UserControl x:Class="Paperhome.Views.InspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="400">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок-таб -->
        <Border Grid.Row="0" Background="#1F1F1F" BorderBrush="#111" BorderThickness="2,2,2,0"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <TextBlock Text="ИНСПЕКТОР" Foreground="#888" FontWeight="Bold" Padding="15,0" VerticalAlignment="Center"/>
        </Border>

        <!-- Фоновый бордер основной зоны -->
        <Border Grid.Row="1" Background="#1F1F1F" BorderBrush="#111" BorderThickness="2"
                RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="0" ShadowDepth="2" Direction="315" Opacity="0.3" Color="Black"/>
            </Border.Effect>
        </Border>

        <Grid Grid.Row="1" Margin="2" UseLayoutRounding="True" SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Тулбар (PDF и изображения) -->
            <Border x:Name="DocToolbar" Grid.Row="0" Background="#2A2A2A" BorderBrush="#111"
                    BorderThickness="0,0,0,2" Visibility="Collapsed"
                    RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Навигация по страницам (только PDF) -->
                    <StackPanel x:Name="PageNavPanel" Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Visibility="Collapsed">
                        <Button Style="{StaticResource MechanicalButton}" Margin="8,0,3,0" Padding="3" Click="BtnPrevPage_Click">
                            <iconPacks:PackIconPixelartIcons Kind="ChevronLeft" Width="16" Height="16"/>
                        </Button>
                        <!-- Вдавленный счётчик страниц -->
                        <Border Background="#0C0C0C" BorderBrush="#1A1A1A" BorderThickness="2" Margin="3,0" VerticalAlignment="Center">
                            <Border BorderBrush="#3A3A3A" BorderThickness="0,0,1,1" Padding="10,4">
                                <TextBlock x:Name="TxtPageCounter" Text="01 / 12" Foreground="#DCA73F" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <Button Style="{StaticResource MechanicalButton}" Margin="3,0,8,0" Padding="3" Click="BtnNextPage_Click">
                            <iconPacks:PackIconPixelartIcons Kind="ChevronRight" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Масштаб и открытие (справа) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource MechanicalButton}" Margin="3,0" Padding="3" Click="BtnZoomOut_Click">
                            <iconPacks:PackIconPixelartIcons Kind="ZoomOut" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource MechanicalButton}" Margin="3,0" Padding="3" Click="BtnFitPage_Click">
                            <iconPacks:PackIconPixelartIcons Kind="AspectRatio" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource MechanicalButton}" Margin="3,0" Padding="3" Click="BtnZoomIn_Click">
                            <iconPacks:PackIconPixelartIcons Kind="ZoomIn" Width="16" Height="16"/>
                        </Button>
                        <Button x:Name="BtnOpenNative" Style="{StaticResource MechanicalButton}" Margin="8,0,8,0" Padding="3" Click="BtnOpenNative_Click">
                            <iconPacks:PackIconPixelartIcons Kind="Link" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основная область вывода документа -->
            <Grid Grid.Row="1" Background="#181818">
                <TextBlock x:Name="TxtPlaceholder" Text="[ВЫВОД ДОКУМЕНТА]" Foreground="#555"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ScrollViewer x:Name="ImgScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <Image x:Name="ImgViewer" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ScrollViewer>
                <TextBox x:Name="TxtViewer" Visibility="Collapsed" IsReadOnly="True" Background="Transparent"
                         Foreground="#DCA73F" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                         BorderThickness="0" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="10"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

<Window x:Class="Paperhome.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="О программе" Height="240" Width="480"
        Icon="pack://application:,,,/Resources/logo.png"
        WindowStyle="None" ResizeMode="NoResize"
        BorderBrush="#C8C8C8"
        BorderThickness="1"
        WindowStartupLocation="CenterOwner"
        Background="#181818"
        TextElement.FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
        TextOptions.TextFormattingMode="Display">

    <Border CornerRadius="8" Background="#181818" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="46"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#181818" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="О ПРОГРАММЕ"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           FontWeight="Bold"/>
                <Button Width="40" HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888888" Click="BtnClose_Click">
                    <iconPacks:PackIconPixelartIcons Kind="Close" Width="12" Height="12"/>
                </Button>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0"
                       Width="120" Height="120"
                       VerticalAlignment="Top" HorizontalAlignment="Left"
                       Stretch="Uniform"
                       Source="pack://application:,,,/Resources/logo.png"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>


                <StackPanel Grid.Column="1" VerticalAlignment="Top">

                    <TextBlock Text="PAPERHOME"
                               Foreground="#C8C8C8"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <TextBlock Text="Персональный менеджер документов"
                               Foreground="#C8C8C8"
                               FontSize="10"
                               Margin="0,3,0,10"/>
                    
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#A0A0A0"
                               LineHeight="16">
                        <Run>Сделал Платон Останин с ❤️ в 2026 году.</Run>
                        <LineBreak/>
                        <Run>в Московском Политехе, город Москва.</Run>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Foreground="#555555">© Все права защищены 2026.</Run>
                        <LineBreak/>
                    </TextBlock>

                </StackPanel>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#222222">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="0" ShadowDepth="4" Direction="90" Opacity="0.5" Color="Black"/>
                </Border.Effect>
            </Border>
        </Grid>
    </Border>
</Window>

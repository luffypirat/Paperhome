<UserControl x:Class="Paperhome.Views.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="320">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#CA9731" BorderBrush="#111" BorderThickness="2,2,2,0"
                HorizontalAlignment="Left" RenderOptions.EdgeMode="Aliased"
                SnapsToDevicePixels="True" UseLayoutRounding="True">
            <TextBlock Text="ХРАНИЛИЩЕ" Foreground="#FFFFFF" FontWeight="Bold"
                       Padding="15,4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Button x:Name="BtnSearch" Grid.Row="0" Margin="0,0,10,0"
                Background="#CA9731" BorderBrush="#111" BorderThickness="2,2,2,0"
                HorizontalAlignment="Right" RenderOptions.EdgeMode="Aliased"
                SnapsToDevicePixels="True" UseLayoutRounding="True"
                Click="BtnSearch_Click">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconPixelartIcons Kind="Search" Width="14" Height="14"
                                                Margin="1,2,1,1" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Панель поиска (скрыта по умолчанию) -->
        <Border x:Name="SearchPanel" Grid.Row="1" Background="#1C1C1C" BorderBrush="#111"
                BorderThickness="2,0,2,2" Visibility="Collapsed"
                RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <TextBox x:Name="TxtSearch"
                     Background="Transparent" Foreground="#DCA73F"
                     FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                     BorderThickness="0" Padding="8,5"
                     CaretBrush="#DCA73F" SelectionBrush="#DCA73F"
                     TextChanged="TxtSearch_TextChanged"/>
        </Border>

        <!-- Фон дерева -->
        <Border Grid.Row="2" Background="{StaticResource DetailedFolderGradient}" BorderBrush="#111"
                BorderThickness="2,0,2,2" RenderOptions.EdgeMode="Aliased">
            <Border.Effect>
                <DropShadowEffect BlurRadius="0" ShadowDepth="4" Direction="315" Opacity="0.4" Color="Black"/>
            </Border.Effect>
        </Border>

        <Grid Grid.Row="2" Margin="2" UseLayoutRounding="True" SnapsToDevicePixels="True">
            <TreeView x:Name="FilesTree" Background="Transparent" BorderThickness="0"
                      FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                      SelectedItemChanged="FilesTree_SelectedItemChanged"
                      Margin="2"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <TreeView.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#000000"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#DDDDDD"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#000000"/>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Foreground" Value="#111"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Padding" Value="4,2"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Paperhome.LockScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             SnapsToDevicePixels="True"
             RenderOptions.EdgeMode="Aliased">
    <Grid Background="#080808">

        <!-- Весь экран — уезжает вверх при разблокировке -->
        <Grid x:Name="ShutterContainer">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ShutterTransform"/>
            </Grid.RenderTransform>

            <!-- Текстура рольставней: горизонтальные ламели -->
            <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,1,28" ViewportUnits="Absolute"
                                  Stretch="None">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#1C1C1C">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,1,24"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#0A0A0A">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,24,1,2"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#2E2E2E">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,26,1,2"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Панель кодового замка -->
            <Border x:Name="LockPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="310"
                    Background="#111111" BorderBrush="#2A2A2A" BorderThickness="2">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ShakeTransform"/>
                </Border.RenderTransform>
                <Border BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="24,22">
                    <StackPanel>

                        <!-- Заголовок -->
                        <TextBlock Text="PAPERHOME"
                                   Foreground="#C8C8C8"
                                   FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="АРХИВ ДОКУМЕНТОВ"
                                   Foreground="#C8C8C8"
                                   FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,18"/>

                        <!-- Статус (терминальный стиль) -->
                        <Border Background="#050808" BorderBrush="#1A2A1A" BorderThickness="2"
                                Margin="0,0,0,18" Padding="1">
                            <Border BorderBrush="#1E3A1E" BorderThickness="1,1,0,0" Padding="8,5">
                                <TextBlock x:Name="TxtStatus"
                                           Text="> ВВЕДИТЕ КОД ДОСТУПА"
                                           Foreground="#60C040"
                                           FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Border>

                        <!-- Точки пина -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,0,0,22">
                            <Rectangle  x:Name="Dot1" Width="14" Height="14" Margin="10,0" Fill="#2A2A2A"/>
                            <Rectangle  x:Name="Dot2" Width="14" Height="14" Margin="10,0" Fill="#2A2A2A"/>
                            <Rectangle  x:Name="Dot3" Width="14" Height="14" Margin="10,0" Fill="#2A2A2A"/>
                            <Rectangle  x:Name="Dot4" Width="14" Height="14" Margin="10,0" Fill="#2A2A2A"/>
                        </StackPanel>

                        <!-- Клавиатура 3×4 -->
                        <UniformGrid Columns="3" HorizontalAlignment="Center">
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="1" Click="PinKey_Click">
                                <TextBlock Text="1" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="2" Click="PinKey_Click">
                                <TextBlock Text="2" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="3" Click="PinKey_Click">
                                <TextBlock Text="3" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="4" Click="PinKey_Click">
                                <TextBlock Text="4" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="5" Click="PinKey_Click">
                                <TextBlock Text="5" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="6" Click="PinKey_Click">
                                <TextBlock Text="6" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="7" Click="PinKey_Click">
                                <TextBlock Text="7" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="8" Click="PinKey_Click">
                                <TextBlock Text="8" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="9" Click="PinKey_Click">
                                <TextBlock Text="9" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Click="BtnBack_Click">
                                <iconPacks:PackIconPixelartIcons Kind="ChevronLeft" Width="16" Height="16" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Tag="0" Click="PinKey_Click">
                                <TextBlock Text="0" FontFamily="pack://application:,,,/Fonts/#Terminus (TTF)" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button Style="{StaticResource MechanicalButton}"
                                    Width="76" Height="52" Margin="3" Click="BtnConfirm_Click">
                                <iconPacks:PackIconPixelartIcons Kind="Check" Width="16" Height="16" VerticalAlignment="Center"/>
                            </Button>
                        </UniformGrid>

                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Grid>
</UserControl>

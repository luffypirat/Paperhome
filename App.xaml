<Application x:Class="Paperhome.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Paperhome"
             >
    <Application.Resources>
        <LinearGradientBrush x:Key="SteppedDeskGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A2A2B" Offset="0.0" />
            <GradientStop Color="#2A2A2B" Offset="0.2" />
            <GradientStop Color="#252526" Offset="0.2" />
            <GradientStop Color="#252526" Offset="0.5" />
            <GradientStop Color="#202021" Offset="0.5" />
            <GradientStop Color="#202021" Offset="0.8" />
            <GradientStop Color="#1C1C1D" Offset="0.8" />
            <GradientStop Color="#1C1C1D" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DetailedFolderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#DCA73F" Offset="0.0" />
            <GradientStop Color="#DCA73F" Offset="0.1" />
            <GradientStop Color="#D39F38" Offset="0.1" />
            <GradientStop Color="#D39F38" Offset="0.2" />
            <GradientStop Color="#CA9731" Offset="0.2" />
            <GradientStop Color="#CA9731" Offset="0.4" />
            <GradientStop Color="#C18F2A" Offset="0.4" />
            <GradientStop Color="#C18F2A" Offset="0.6" />
            <GradientStop Color="#B88723" Offset="0.6" />
            <GradientStop Color="#B88723" Offset="0.8" />
            <GradientStop Color="#AF7F1C" Offset="0.8" />
            <GradientStop Color="#AF7F1C" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="MechanicalButton" TargetType="Button">
            <Setter Property="Background" Value="#A0A0A0"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="RenderOptions.EdgeMode" Value="Aliased"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#333333" Padding="2" CornerRadius="0" SnapsToDevicePixels="True">
                            <Border x:Name="ButtonFace" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="2,2,2,6" 
                                    CornerRadius="0"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center" 
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFace" Property="BorderThickness" Value="2,2,2,2"/>
                                <Setter TargetName="ButtonFace" Property="Margin" Value="0,4,0,0"/>
                                <Setter TargetName="ButtonFace" Property="Background" Value="#8A8A8A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="Background" Value="#B4B4B4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PixelBox" TargetType="ContentControl">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="RenderOptions.EdgeMode" Value="Aliased"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" Margin="2,0" SnapsToDevicePixels="True"/>
                            <Border Background="{TemplateBinding Background}" Margin="0,2" SnapsToDevicePixels="True"/>
                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,2" Margin="2,0" SnapsToDevicePixels="True"/>
                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="2,0" Margin="0,2" SnapsToDevicePixels="True"/>
                    
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Невидимые кнопки для скроллбара (кликабельная область трека) -->
        <Style x:Key="ScrollRepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Rectangle Fill="{TemplateBinding Background}" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ползунок скроллбара -->
        <Style x:Key="ThinScrollThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="0" RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кастомный тонкий механический скроллбар -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Width="8" Background="{TemplateBinding Background}">
                            <!-- Трек -->
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButtonTransparent}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollThumb}" Background="{TemplateBinding Foreground}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButtonTransparent}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid x:Name="GridRoot" Height="8" Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollRepeatButtonTransparent}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ThinScrollThumb}" Background="{TemplateBinding Foreground}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollRepeatButtonTransparent}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter Property="Foreground" Value="#888888"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
